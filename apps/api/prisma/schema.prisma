generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// CORE: IDENTIDAD E INSTITUCIÓN
// ============================================================

model Institution {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(200)
  code      String   @unique @db.VarChar(50)
  settings  Json     @default("{}")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users                 User[]
  roles                 Role[]
  levels                Level[]
  subjects              Subject[]
  academicYears         AcademicYear[]
  parallels             Parallel[]
  activityTypes         ActivityType[]
  courseAssignments     CourseAssignment[]
  studentEnrollments    StudentEnrollment[]
  activities            Activity[]
  grades                Grade[]
  attendanceRecords     AttendanceRecord[]
  absenceJustifications AbsenceJustification[]
  disciplinaryIncidents DisciplinaryIncident[]
  messageThreads        MessageThread[]
  scheduleEntries       ScheduleEntry[]
  reportTemplates       ReportTemplate[]
  auditLogs             AuditLog[]
  insumos               Insumo[]
  tasks                 Task[]

  @@map("institutions")
}

model User {
  id            String    @id @default(uuid())
  institutionId String    @map("institution_id")
  email         String    @db.VarChar(255)
  passwordHash  String    @map("password_hash") @db.VarChar(255)
  isActive      Boolean   @default(true) @map("is_active")
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  institution Institution @relation(fields: [institutionId], references: [id])
  profile     Profile?
  userRoles   UserRole[]

  // Relaciones como actor
  teacherAssignments     CourseAssignment[]     @relation("TeacherAssignments")
  createdActivities      Activity[]             @relation("ActivityCreator")
  recordedGrades         Grade[]                @relation("GradeRecorder")
  recordedAttendance     AttendanceRecord[]     @relation("AttendanceRecorder")
  reportedIncidents      DisciplinaryIncident[] @relation("IncidentReporter")
  createdJustifications  AbsenceJustification[] @relation("JustificationCreator")
  sentMessages           Message[]              @relation("MessageSender")
  messageRecipients      MessageRecipient[]
  createdThreads         MessageThread[]        @relation("ThreadCreator")
  createdInsumos         Insumo[]               @relation("InsumoCreator")
  createdTasks           Task[]                 @relation("TaskCreator")
  uploadedAttachments    TaskAttachment[]       @relation("AttachmentUploader")

  // Relaciones como alumno
  studentEnrollments    StudentEnrollment[]    @relation("StudentEnrollments")
  studentGrades         Grade[]                @relation("StudentGrades")
  studentAttendance     AttendanceRecord[]     @relation("StudentAttendance")
  studentIncidents      DisciplinaryIncident[] @relation("StudentIncidents")
  studentJustifications AbsenceJustification[] @relation("StudentJustifications")

  // Relaciones de tutor/padre
  guardianOf       GuardianStudent[] @relation("GuardianRelation")
  studentGuardians GuardianStudent[] @relation("StudentRelation")
  tutoredParallels Parallel[]        @relation("ParallelTutor")

  assignedRoles   UserRole[]  @relation("RoleAssigner")

  @@unique([institutionId, email])
  @@map("users")
}

model Profile {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  firstName String   @map("first_name") @db.VarChar(100)
  lastName  String   @map("last_name") @db.VarChar(100)
  dni       String?  @db.VarChar(20)
  phone     String?  @db.VarChar(30)
  birthDate DateTime? @map("birth_date") @db.Date
  avatarUrl String?  @map("avatar_url") @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model GuardianStudent {
  guardianId   String @map("guardian_id")
  studentId    String @map("student_id")
  relationship String @default("guardian") @db.VarChar(50)
  isPrimary    Boolean @default(false) @map("is_primary")

  guardian User @relation("GuardianRelation", fields: [guardianId], references: [id], onDelete: Cascade)
  student  User @relation("StudentRelation", fields: [studentId], references: [id], onDelete: Cascade)

  @@id([guardianId, studentId])
  @@map("guardian_students")
}

// ============================================================
// RBAC
// ============================================================

model Role {
  id            String   @id @default(uuid())
  institutionId String   @map("institution_id")
  name          String   @db.VarChar(100)
  label         String   @db.VarChar(100)
  isSystem      Boolean  @default(false) @map("is_system")
  createdAt     DateTime @default(now()) @map("created_at")

  institution     Institution      @relation(fields: [institutionId], references: [id])
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([institutionId, name])
  @@map("roles")
}

model Permission {
  id          String  @id @default(uuid())
  resource    String  @db.VarChar(100)
  action      String  @db.VarChar(50)
  scope       String  @default("all") @db.VarChar(50)
  description String? @db.VarChar(200)

  rolePermissions RolePermission[]

  @@unique([resource, action, scope])
  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId     String   @map("user_id")
  roleId     String   @map("role_id")
  assignedBy String?  @map("assigned_by")
  assignedAt DateTime @default(now()) @map("assigned_at")

  user     User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assigner User? @relation("RoleAssigner", fields: [assignedBy], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

// ============================================================
// ESTRUCTURA ACADÉMICA
// ============================================================

model AcademicYear {
  id            String   @id @default(uuid())
  institutionId String   @map("institution_id")
  name          String   @db.VarChar(50)
  startDate     DateTime @map("start_date") @db.Date
  endDate       DateTime @map("end_date") @db.Date
  isActive      Boolean  @default(false) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  institution     Institution      @relation(fields: [institutionId], references: [id])
  academicPeriods AcademicPeriod[]
  parallels       Parallel[]
  enrollments     StudentEnrollment[]
  courseAssignments CourseAssignment[]

  @@unique([institutionId, name])
  @@map("academic_years")
}

model AcademicPeriodScheme {
  id            String   @id @default(uuid())
  institutionId String   @map("institution_id")
  name          String   @db.VarChar(100)
  code          String   @db.VarChar(50)
  periodsCount  Int      @map("periods_count") @db.SmallInt
  config        Json     @default("{}")
  isDefault     Boolean  @default(false) @map("is_default")
  createdAt     DateTime @default(now()) @map("created_at")

  academicPeriods AcademicPeriod[]

  @@map("academic_period_schemes")
}

model AcademicPeriod {
  id             String   @id @default(uuid())
  academicYearId String   @map("academic_year_id")
  schemeId       String   @map("scheme_id")
  periodNumber   Int      @map("period_number") @db.SmallInt
  name           String   @db.VarChar(100)
  startDate      DateTime @map("start_date") @db.Date
  endDate        DateTime @map("end_date") @db.Date
  isActive       Boolean  @default(false) @map("is_active")

  academicYear AcademicYear         @relation(fields: [academicYearId], references: [id])
  scheme       AcademicPeriodScheme @relation(fields: [schemeId], references: [id])
  activities   Activity[]
  insumos      Insumo[]

  @@unique([academicYearId, periodNumber])
  @@map("academic_periods")
}

model Level {
  id            String   @id @default(uuid())
  institutionId String   @map("institution_id")
  name          String   @db.VarChar(100)
  code          String   @db.VarChar(20)
  sortOrder     Int      @map("sort_order") @db.SmallInt
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  institution Institution @relation(fields: [institutionId], references: [id])
  parallels   Parallel[]

  @@unique([institutionId, code])
  @@map("levels")
}

model Parallel {
  id             String   @id @default(uuid())
  institutionId  String   @map("institution_id")
  levelId        String   @map("level_id")
  academicYearId String   @map("academic_year_id")
  tutorId        String?  @map("tutor_id")
  name           String   @db.VarChar(10)
  capacity       Int?     @db.SmallInt
  isActive       Boolean  @default(true) @map("is_active")

  institution      Institution        @relation(fields: [institutionId], references: [id])
  level            Level              @relation(fields: [levelId], references: [id])
  academicYear     AcademicYear       @relation(fields: [academicYearId], references: [id])
  tutor            User?              @relation("ParallelTutor", fields: [tutorId], references: [id])
  enrollments      StudentEnrollment[]
  courseAssignments CourseAssignment[]

  @@unique([levelId, academicYearId, name])
  @@map("parallels")
}

model Subject {
  id            String   @id @default(uuid())
  institutionId String   @map("institution_id")
  name          String   @db.VarChar(150)
  code          String?  @db.VarChar(20)
  description   String?
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  institution       Institution        @relation(fields: [institutionId], references: [id])
  courseAssignments CourseAssignment[]

  @@unique([institutionId, code])
  @@map("subjects")
}

model CourseAssignment {
  id             String   @id @default(uuid())
  institutionId  String   @map("institution_id")
  teacherId      String   @map("teacher_id")
  subjectId      String   @map("subject_id")
  parallelId     String   @map("parallel_id")
  academicYearId String   @map("academic_year_id")
  isActive       Boolean  @default(true) @map("is_active")
  examWeight     Int      @default(30) @map("exam_weight")
  createdAt      DateTime @default(now()) @map("created_at")

  institution  Institution        @relation(fields: [institutionId], references: [id])
  teacher      User               @relation("TeacherAssignments", fields: [teacherId], references: [id])
  subject      Subject            @relation(fields: [subjectId], references: [id])
  parallel     Parallel           @relation(fields: [parallelId], references: [id])
  academicYear AcademicYear       @relation(fields: [academicYearId], references: [id])
  activities   Activity[]
  insumos      Insumo[]
  attendance   AttendanceRecord[]
  schedule     ScheduleEntry[]
  tasks        Task[]

  @@unique([subjectId, parallelId, academicYearId])
  @@map("course_assignments")
}

// ============================================================
// MATRÍCULA
// ============================================================

model StudentEnrollment {
  id             String   @id @default(uuid())
  institutionId  String   @map("institution_id")
  studentId      String   @map("student_id")
  parallelId     String   @map("parallel_id")
  academicYearId String   @map("academic_year_id")
  enrolledAt     DateTime @default(now()) @map("enrolled_at")
  status         String   @default("active") @db.VarChar(20)

  institution  Institution  @relation(fields: [institutionId], references: [id])
  student      User         @relation("StudentEnrollments", fields: [studentId], references: [id])
  parallel     Parallel     @relation(fields: [parallelId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  @@unique([studentId, academicYearId])
  @@map("student_enrollments")
}

// ============================================================
// ACTIVIDADES Y CALIFICACIONES
// ============================================================

model ActivityType {
  id            String   @id @default(uuid())
  institutionId String   @map("institution_id")
  name          String   @db.VarChar(100)
  code          String   @db.VarChar(50)
  description   String?
  isActive      Boolean  @default(true) @map("is_active")
  sortOrder     Int      @default(0) @map("sort_order") @db.SmallInt
  metadata      Json     @default("{}")
  createdAt     DateTime @default(now()) @map("created_at")

  institution Institution @relation(fields: [institutionId], references: [id])
  activities  Activity[]

  @@unique([institutionId, code])
  @@map("activity_types")
}

model Insumo {
  id                 String   @id @default(uuid())
  institutionId      String   @map("institution_id")
  courseAssignmentId String   @map("course_assignment_id")
  academicPeriodId   String   @map("academic_period_id")
  name               String   @db.VarChar(100)
  sortOrder          Int      @default(0) @map("sort_order") @db.SmallInt
  weight             Decimal? @db.Decimal(5, 2)
  createdBy          String   @map("created_by")
  createdAt          DateTime @default(now()) @map("created_at")

  institution      Institution      @relation(fields: [institutionId], references: [id])
  courseAssignment CourseAssignment @relation(fields: [courseAssignmentId], references: [id])
  academicPeriod   AcademicPeriod   @relation(fields: [academicPeriodId], references: [id])
  creator          User             @relation("InsumoCreator", fields: [createdBy], references: [id])
  activities       Activity[]

  @@index([courseAssignmentId, academicPeriodId])
  @@map("insumos")
}

model Activity {
  id                 String    @id @default(uuid())
  institutionId      String    @map("institution_id")
  courseAssignmentId String    @map("course_assignment_id")
  academicPeriodId   String    @map("academic_period_id")
  activityTypeId     String    @map("activity_type_id")
  insumoId           String?   @map("insumo_id")
  name               String    @db.VarChar(200)
  description        String?
  maxScore           Decimal   @default(10) @map("max_score") @db.Decimal(5, 2)
  activityDate       DateTime? @map("activity_date") @db.Date
  isPublished        Boolean   @default(false) @map("is_published")
  metadata           Json      @default("{}")
  createdBy          String    @map("created_by")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  institution      Institution      @relation(fields: [institutionId], references: [id])
  courseAssignment CourseAssignment @relation(fields: [courseAssignmentId], references: [id])
  academicPeriod   AcademicPeriod   @relation(fields: [academicPeriodId], references: [id])
  activityType     ActivityType     @relation(fields: [activityTypeId], references: [id])
  insumo           Insumo?          @relation(fields: [insumoId], references: [id])
  creator          User             @relation("ActivityCreator", fields: [createdBy], references: [id])
  grades           Grade[]

  @@index([courseAssignmentId, academicPeriodId])
  @@index([insumoId])
  @@map("activities")
}

model Grade {
  id            String    @id @default(uuid())
  institutionId String    @map("institution_id")
  activityId    String    @map("activity_id")
  studentId     String    @map("student_id")
  score         Decimal?  @db.Decimal(5, 2)
  isExcused     Boolean   @default(false) @map("is_excused")
  notes         String?
  gradedBy      String?   @map("graded_by")
  gradedAt      DateTime? @map("graded_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  institution Institution @relation(fields: [institutionId], references: [id])
  activity    Activity    @relation(fields: [activityId], references: [id])
  student     User        @relation("StudentGrades", fields: [studentId], references: [id])
  grader      User?       @relation("GradeRecorder", fields: [gradedBy], references: [id])

  @@unique([activityId, studentId])
  @@index([studentId])
  @@map("grades")
}

// ============================================================
// ASISTENCIA
// ============================================================

model AttendanceRecord {
  id                 String   @id @default(uuid())
  institutionId      String   @map("institution_id")
  courseAssignmentId String   @map("course_assignment_id")
  studentId          String   @map("student_id")
  date               DateTime @db.Date
  status             String   @default("present") @db.VarChar(20)
  notes              String?
  recordedBy         String   @map("recorded_by")
  createdAt          DateTime @default(now()) @map("created_at")

  institution      Institution      @relation(fields: [institutionId], references: [id])
  courseAssignment CourseAssignment @relation(fields: [courseAssignmentId], references: [id])
  student          User             @relation("StudentAttendance", fields: [studentId], references: [id])
  recorder         User             @relation("AttendanceRecorder", fields: [recordedBy], references: [id])
  justifications   JustificationAttendance[]

  @@unique([courseAssignmentId, studentId, date])
  @@index([courseAssignmentId, date])
  @@index([studentId])
  @@map("attendance_records")
}

model AbsenceJustification {
  id            String   @id @default(uuid())
  institutionId String   @map("institution_id")
  studentId     String   @map("student_id")
  reason        String
  documentUrl   String?  @map("document_url") @db.VarChar(500)
  justifiedBy   String   @map("justified_by")
  createdAt     DateTime @default(now()) @map("created_at")

  institution      Institution               @relation(fields: [institutionId], references: [id])
  student          User                      @relation("StudentJustifications", fields: [studentId], references: [id])
  justifier        User                      @relation("JustificationCreator", fields: [justifiedBy], references: [id])
  attendanceRecords JustificationAttendance[]

  @@map("absence_justifications")
}

model JustificationAttendance {
  justificationId    String @map("justification_id")
  attendanceRecordId String @map("attendance_record_id")

  justification    AbsenceJustification @relation(fields: [justificationId], references: [id], onDelete: Cascade)
  attendanceRecord AttendanceRecord     @relation(fields: [attendanceRecordId], references: [id], onDelete: Cascade)

  @@id([justificationId, attendanceRecordId])
  @@map("justification_attendance")
}

// ============================================================
// DISCIPLINA
// ============================================================

model DisciplinaryIncident {
  id              String    @id @default(uuid())
  institutionId   String    @map("institution_id")
  studentId       String    @map("student_id")
  reportedBy      String    @map("reported_by")
  incidentDate    DateTime  @map("incident_date") @db.Date
  category        String    @db.VarChar(100)
  description     String
  severity        String    @default("low") @db.VarChar(20)
  status          String    @default("open") @db.VarChar(20)
  resolutionNotes String?   @map("resolution_notes")
  resolvedAt      DateTime? @map("resolved_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  institution Institution @relation(fields: [institutionId], references: [id])
  student     User        @relation("StudentIncidents", fields: [studentId], references: [id])
  reporter    User        @relation("IncidentReporter", fields: [reportedBy], references: [id])

  @@index([studentId, incidentDate])
  @@map("disciplinary_incidents")
}

// ============================================================
// MENSAJERÍA
// ============================================================

model MessageThread {
  id            String   @id @default(uuid())
  institutionId String   @map("institution_id")
  subject       String   @db.VarChar(300)
  createdBy     String   @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")

  institution Institution @relation(fields: [institutionId], references: [id])
  creator     User        @relation("ThreadCreator", fields: [createdBy], references: [id])
  messages    Message[]

  @@map("message_threads")
}

model Message {
  id       String   @id @default(uuid())
  threadId String   @map("thread_id")
  senderId String   @map("sender_id")
  body     String
  sentAt   DateTime @default(now()) @map("sent_at")

  thread      MessageThread       @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender      User                @relation("MessageSender", fields: [senderId], references: [id])
  recipients  MessageRecipient[]
  attachments MessageAttachment[]

  @@index([threadId, sentAt])
  @@map("messages")
}

model MessageAttachment {
  id         String   @id @default(uuid())
  messageId  String   @map("message_id")
  fileName   String   @map("file_name") @db.VarChar(255)
  storedName String   @map("stored_name") @db.VarChar(255)
  mimeType   String   @map("mime_type") @db.VarChar(100)
  fileSize   Int      @map("file_size")
  createdAt  DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("message_attachments")
}

model MessageRecipient {
  messageId   String    @map("message_id")
  recipientId String    @map("recipient_id")
  isRead      Boolean   @default(false) @map("is_read")
  readAt      DateTime? @map("read_at")

  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  recipient User    @relation(fields: [recipientId], references: [id])

  @@id([messageId, recipientId])
  @@index([recipientId, isRead])
  @@map("message_recipients")
}

// ============================================================
// HORARIO
// ============================================================

model ScheduleEntry {
  id                 String @id @default(uuid())
  institutionId      String @map("institution_id")
  courseAssignmentId String @map("course_assignment_id")
  weekday            Int    @db.SmallInt
  startTime          String @map("start_time") @db.VarChar(5)
  endTime            String @map("end_time") @db.VarChar(5)
  room               String? @db.VarChar(50)

  institution      Institution      @relation(fields: [institutionId], references: [id])
  courseAssignment CourseAssignment @relation(fields: [courseAssignmentId], references: [id])

  @@unique([courseAssignmentId, weekday, startTime])
  @@map("schedule_entries")
}

// ============================================================
// REPORTES
// ============================================================

model ReportTemplate {
  id            String   @id @default(uuid())
  institutionId String   @map("institution_id")
  name          String   @db.VarChar(200)
  type          String   @db.VarChar(50)
  templateBody  String   @map("template_body")
  variables     Json     @default("{}")
  isDefault     Boolean  @default(false) @map("is_default")
  createdBy     String?  @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  institution Institution @relation(fields: [institutionId], references: [id])

  @@map("report_templates")
}

// ============================================================
// AUDITORÍA
// ============================================================

model AuditLog {
  id            String   @id @default(uuid())
  institutionId String?  @map("institution_id")
  userId        String?  @map("user_id")
  action        String   @db.VarChar(100)
  resourceType  String   @map("resource_type") @db.VarChar(100)
  resourceId    String?  @map("resource_id")
  oldValue      Json?    @map("old_value")
  newValue      Json?    @map("new_value")
  ipAddress     String?  @map("ip_address") @db.VarChar(45)
  userAgent     String?  @map("user_agent")
  createdAt     DateTime @default(now()) @map("created_at")

  institution Institution? @relation(fields: [institutionId], references: [id])

  @@index([resourceType, resourceId])
  @@index([userId, createdAt])
  @@map("audit_logs")
}

// ============================================================
// TAREAS
// ============================================================

model Task {
  id                 String    @id @default(uuid())
  institutionId      String    @map("institution_id")
  courseAssignmentId String    @map("course_assignment_id")
  title              String    @db.VarChar(255)
  description        String?
  dueDate            DateTime  @map("due_date")
  publishAt          DateTime  @default(now()) @map("publish_at")
  isPublished        Boolean   @default(false) @map("is_published")
  createdBy          String    @map("created_by")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  institution      Institution      @relation(fields: [institutionId], references: [id])
  courseAssignment CourseAssignment @relation(fields: [courseAssignmentId], references: [id])
  creator          User             @relation("TaskCreator", fields: [createdBy], references: [id])
  attachments      TaskAttachment[]

  @@index([institutionId, courseAssignmentId])
  @@index([institutionId, dueDate])
  @@map("tasks")
}

model TaskAttachment {
  id           String   @id @default(uuid())
  taskId       String   @map("task_id")
  institutionId String  @map("institution_id")
  fileName     String   @map("file_name") @db.VarChar(255)
  storedName   String   @map("stored_name") @db.VarChar(255)
  mimeType     String   @map("mime_type") @db.VarChar(100)
  fileSize     Int      @map("file_size")
  uploadedBy   String   @map("uploaded_by")
  createdAt    DateTime @default(now()) @map("created_at")

  task      Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploader  User @relation("AttachmentUploader", fields: [uploadedBy], references: [id])

  @@map("task_attachments")
}
