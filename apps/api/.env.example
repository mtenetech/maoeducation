NODE_ENV=production
PORT=3000

# Base de datos.
# - DATABASE_URL: en producción con PgBouncer, apunta al POOLER y agrega ?pgbouncer=true
# - DIRECT_URL: conexión DIRECTA a Postgres (la usan las migraciones). En local
#   ambas pueden ser iguales.
DATABASE_URL=postgresql://user:password@host:5432/dbname
DIRECT_URL=postgresql://user:password@host:5432/dbname

JWT_SECRET=cambia_esto_por_un_secreto_de_al_menos_32_caracteres
JWT_REFRESH_SECRET=otro_secreto_distinto_de_al_menos_32_caracteres
FRONTEND_URL=https://tu-web.up.railway.app

# Almacenamiento de archivos (adjuntos de tareas, mensajes, incidentes).
# Si no defines nada => "local" (disco, EFÍMERO en Railway: se borra al redeploy).
# Para producción usa un bucket S3-compatible (Cloudflare R2 recomendado):
#   STORAGE_DRIVER=s3
#   S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
#   S3_BUCKET=mao-uploads
#   S3_ACCESS_KEY_ID=...
#   S3_SECRET_ACCESS_KEY=...
#   S3_REGION=auto
STORAGE_DRIVER=local
