---
import Layout from '../layouts/Layout.astro'
import Footer from '../components/Footer.astro'

const appUrl = import.meta.env.PUBLIC_APP_URL || 'https://app.auleka.com'
const registerUrl = `${appUrl}/personal/register`
const shareText = encodeURIComponent('Profe, encontré esta herramienta gratis para llevar calificaciones y asistencia sin depender del sistema del colegio 👇 https://auleka.com/personal')
const whatsappUrl = `https://wa.me/?text=${shareText}`
---

<Layout
  title="Auleka para Profesores — Gratis para siempre"
  description="Calificaciones, asistencia y reportes con tu logo. Gratis para siempre para profesores. Sin depender del sistema de tu institución."
>
  <!-- Header -->
  <header class="sticky top-0 z-40 border-b border-slate-100 bg-white/90 backdrop-blur">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-5 py-3">
      <a href="/" class="flex items-center gap-2" aria-label="Auleka">
        <img src="/isotipo.svg" alt="Auleka" width="34" height="34" />
        <span class="font-display text-xl font-bold tracking-tight text-slate-900">auleka</span>
      </a>
      <nav class="hidden items-center gap-7 text-sm font-medium text-slate-600 md:flex">
        <a href="#como-funciona" class="hover:text-brand-blue">Cómo funciona</a>
        <a href="#funciones" class="hover:text-brand-blue">Funciones</a>
        <a href="/" class="hover:text-brand-blue">Para instituciones</a>
      </nav>
      <div class="flex items-center gap-3">
        <a href={`${appUrl}/personal/login`} class="hidden text-sm font-semibold text-slate-600 hover:text-brand-blue sm:inline">
          Ingresar
        </a>
        <a href={registerUrl} class="rounded-lg bg-brand-blue px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-brand-blue-dark">
          Crear aula — es gratis
        </a>
      </div>
    </div>
  </header>

  <main>
    <!-- Hero -->
    <section class="relative overflow-hidden bg-white">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-1 bg-brand-gradient"></div>
      <div class="pointer-events-none absolute -right-32 -top-32 h-[500px] w-[500px] rounded-full bg-brand-blue/5 blur-3xl"></div>
      <div class="pointer-events-none absolute -bottom-32 -left-32 h-96 w-96 rounded-full bg-brand-green/5 blur-3xl"></div>

      <div class="mx-auto max-w-6xl px-5 py-16 md:py-24 grid md:grid-cols-2 gap-12 items-center">
        <div>
          <!-- Pill gratis para siempre -->
          <div class="inline-flex items-center gap-2 rounded-full bg-green-50 border border-green-200 px-3 py-1.5 text-sm font-bold text-brand-green-dark mb-5">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-green opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-brand-green"></span>
            </span>
            Gratis para siempre · Sin tarjeta · Sin trampa
          </div>

          <h1 class="font-display text-4xl md:text-5xl font-extrabold leading-[1.1] tracking-tight text-slate-900">
            Profe, deja de pelear<br/>
            <span class="bg-brand-gradient bg-clip-text text-transparent">con el sistema.</span>
          </h1>

          <p class="mt-5 text-lg leading-relaxed text-slate-600 max-w-md">
            Calificaciones, asistencia y reportes con tu logo — en tu propio espacio digital.
            <strong class="text-slate-800">Sin esperar al admin. Sin depender de nadie.</strong>
          </p>

          <div class="mt-6 flex flex-wrap gap-2 text-xs font-semibold">
            <span class="rounded-full bg-blue-50 text-brand-blue px-3 py-1">📚 Profe de materia</span>
            <span class="rounded-full bg-green-50 text-brand-green-dark px-3 py-1">🏫 Profe de aula</span>
            <span class="rounded-full bg-purple-50 text-purple-700 px-3 py-1">🎓 Clases particulares</span>
            <span class="rounded-full bg-orange-50 text-orange-700 px-3 py-1">🎨 Academia / taller</span>
          </div>

          <div class="mt-8 flex flex-col sm:flex-row gap-3">
            <a href={registerUrl} class="inline-flex items-center justify-center gap-2 rounded-xl bg-brand-blue px-6 py-3.5 text-base font-bold text-white shadow-lg shadow-blue-200 transition hover:bg-brand-blue-dark">
              Crear mi aula gratis →
            </a>
            <a href={whatsappUrl} target="_blank" rel="noopener"
              class="inline-flex items-center justify-center gap-2 rounded-xl border-2 border-[#25D366] px-6 py-3.5 text-base font-bold text-[#128C7E] transition hover:bg-green-50">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 fill-[#25D366]" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Compartir con colegas
            </a>
          </div>

          <p class="mt-3 text-sm text-slate-400">✓ Sin tarjeta &nbsp;·&nbsp; ✓ Sin instalación &nbsp;·&nbsp; ✓ Listo en 5 minutos</p>
        </div>

        <!-- Mockup -->
        <div class="relative">
          <div class="rounded-2xl border border-slate-200 bg-white p-2 shadow-2xl shadow-slate-200/60">
            <div class="flex items-center gap-1.5 px-3 py-2">
              <span class="h-2.5 w-2.5 rounded-full bg-red-400"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-amber-400"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-green-400"></span>
              <span class="ml-2 text-xs text-slate-400">Mi aula · Matemáticas 3ro A</span>
            </div>
            <div class="rounded-xl bg-slate-50 p-5 space-y-3">
              <div class="flex items-center justify-between">
                <p class="text-sm font-bold text-slate-800">Calificaciones — Trimestre 1</p>
                <span class="rounded-full bg-green-100 px-2 py-0.5 text-xs font-semibold text-brand-green-dark">✓ Al día</span>
              </div>
              {[
                { name: 'Ana García', nota: '9.4', estado: 'DAR' },
                { name: 'Juan López', nota: '8.1', estado: 'AAR' },
                { name: 'Sofía Torres', nota: '7.6', estado: 'AAR' },
                { name: 'Diego Muñoz', nota: '5.2', estado: 'PAAR' },
              ].map(({ name, nota, estado }) => (
                <div class="flex items-center justify-between rounded-lg bg-white px-3 py-2 shadow-sm">
                  <span class="text-sm text-slate-600">{name}</span>
                  <div class="flex items-center gap-2">
                    <span class="text-sm font-bold text-slate-800">{nota}</span>
                    <span class={`text-xs px-1.5 py-0.5 rounded font-semibold ${estado === 'DAR' ? 'bg-green-100 text-green-700' : estado === 'AAR' ? 'bg-blue-100 text-blue-700' : 'bg-yellow-100 text-yellow-700'}`}>{estado}</span>
                  </div>
                </div>
              ))}
              <div class="rounded-lg border border-blue-100 bg-blue-50 px-3 py-2 flex items-center gap-2">
                <span>📄</span>
                <p class="text-xs text-blue-700 font-medium">Boletín generado — con tu logo</p>
              </div>
            </div>
          </div>
          <div class="absolute -bottom-4 -right-4 rounded-xl border border-slate-200 bg-white px-4 py-3 shadow-lg">
            <p class="text-xs font-bold text-green-600">$0 / mes · Para siempre</p>
            <p class="text-xs text-slate-500">Sin límite de estudiantes</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Banner gratis para siempre -->
    <section class="bg-brand-gradient py-10">
      <div class="mx-auto max-w-4xl px-5 text-center">
        <p class="font-display text-2xl md:text-3xl font-extrabold text-white">
          Gratis para siempre. Sin límite de estudiantes. Sin cobros ocultos.
        </p>
        <p class="mt-2 text-white/80 text-base">
          Auleka para profesores individuales no tiene costo — nunca. El producto para instituciones es el que se cobra.
        </p>
      </div>
    </section>

    <!-- Problema → Solución -->
    <section class="bg-slate-50 py-16">
      <div class="mx-auto max-w-4xl px-5">
        <p class="text-center text-sm font-semibold uppercase tracking-wide text-brand-blue mb-8">¿Te suena familiar?</p>
        <div class="grid gap-6 md:grid-cols-2">
          <div class="rounded-2xl border border-red-100 bg-red-50 p-6">
            <p class="text-xs font-bold uppercase tracking-wider text-red-400 mb-4">❌ Sin Auleka</p>
            <ul class="space-y-3 text-sm text-slate-700">
              <li class="flex items-start gap-2"><span class="text-red-400 shrink-0">✗</span> El sistema del colegio no te deja acceder desde casa</li>
              <li class="flex items-start gap-2"><span class="text-red-400 shrink-0">✗</span> Llevas las notas en un cuaderno o en Excel</li>
              <li class="flex items-start gap-2"><span class="text-red-400 shrink-0">✗</span> Para el cierre del trimestre pasas horas calculando</li>
              <li class="flex items-start gap-2"><span class="text-red-400 shrink-0">✗</span> Los reportes no tienen tu nombre ni tu logo</li>
              <li class="flex items-start gap-2"><span class="text-red-400 shrink-0">✗</span> Das clases particulares y no tienes cómo organizarte</li>
            </ul>
          </div>
          <div class="rounded-2xl border border-green-100 bg-green-50 p-6">
            <p class="text-xs font-bold uppercase tracking-wider text-brand-green-dark mb-4">✅ Con Auleka</p>
            <ul class="space-y-3 text-sm text-slate-700">
              <li class="flex items-start gap-2"><span class="text-brand-green shrink-0">✓</span> Accede desde cualquier dispositivo, en cualquier lugar</li>
              <li class="flex items-start gap-2"><span class="text-brand-green shrink-0">✓</span> Notas y asistencia organizadas, sin fórmulas de Excel</li>
              <li class="flex items-start gap-2"><span class="text-brand-green shrink-0">✓</span> Boletines generados en un clic al cerrar el trimestre</li>
              <li class="flex items-start gap-2"><span class="text-brand-green shrink-0">✓</span> Reportes PDF con tu nombre y tu logo</li>
              <li class="flex items-start gap-2"><span class="text-brand-green shrink-0">✓</span> Funciona para cualquier tipo de clase o academia</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Cómo funciona -->
    <section id="como-funciona" class="bg-white py-20">
      <div class="mx-auto max-w-4xl px-5">
        <p class="text-center text-sm font-semibold uppercase tracking-wide text-brand-blue">Cómo funciona</p>
        <h2 class="mt-3 text-center font-display text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">
          De cero a calificando en 5 minutos.
        </h2>
        <div class="mt-12 grid gap-8 md:grid-cols-3">
          {[
            {
              step: '01',
              icon: '👤',
              title: 'Crea tu cuenta',
              desc: 'Solo nombre, email y contraseña. Sin código de institución, sin pagos, sin trampa. 30 segundos.',
              color: 'blue',
            },
            {
              step: '02',
              icon: '🧙',
              title: 'El wizard te guía',
              desc: 'Te pregunta cómo enseñas y configura tu aula automáticamente. Tus materias, tus grupos, tu año escolar.',
              color: 'green',
            },
            {
              step: '03',
              icon: '🚀',
              title: 'Empieza a trabajar',
              desc: 'Sube tu lista desde Excel, registra notas y asistencia, genera reportes. Todo listo para usar.',
              color: 'blue',
            },
          ].map(({ step, icon, title, desc, color }) => (
            <div class="flex flex-col gap-4">
              <div class={`inline-flex h-14 w-14 items-center justify-center rounded-2xl text-2xl ${color === 'blue' ? 'bg-blue-50' : 'bg-green-50'}`}>
                {icon}
              </div>
              <div>
                <span class={`text-xs font-bold uppercase tracking-widest ${color === 'blue' ? 'text-brand-blue' : 'text-brand-green-dark'}`}>Paso {step}</span>
                <h3 class="mt-1 font-display text-lg font-bold text-slate-900">{title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-slate-600">{desc}</p>
              </div>
            </div>
          ))}
        </div>
        <div class="mt-12 text-center">
          <a href={registerUrl} class="inline-flex rounded-xl bg-brand-blue px-8 py-3.5 text-base font-bold text-white shadow-lg shadow-blue-200 transition hover:bg-brand-blue-dark">
            Empezar ahora — gratis para siempre →
          </a>
        </div>
      </div>
    </section>

    <!-- Funciones -->
    <section id="funciones" class="bg-slate-50 py-20">
      <div class="mx-auto max-w-5xl px-5">
        <p class="text-center text-sm font-semibold uppercase tracking-wide text-brand-blue">Funciones</p>
        <h2 class="mt-3 text-center font-display text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">
          Todo lo que necesitas. Nada de lo que no.
        </h2>
        <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: '📊', title: 'Importa desde Excel', desc: 'Sube tu lista de estudiantes en un .xlsx. Detectamos las columnas y creamos todos los perfiles en segundos.' },
            { icon: '📝', title: 'Calificaciones completas', desc: 'Insumos, actividades, notas parciales y finales. El mismo motor que usan las instituciones grandes.' },
            { icon: '📅', title: 'Asistencia por clase', desc: 'Registra asistencia por materia y paralelo. Porcentajes y ausencias visibles al instante.' },
            { icon: '📄', title: 'Reportes con tu logo', desc: 'Boletines y reportes en PDF con el nombre de tu aula y tu logo. Aspecto profesional desde el día uno.' },
            { icon: '🎓', title: 'Para cualquier perfil', desc: 'Profe de materia con varios grupos, profe de aula, docente particular, academia. El wizard se adapta a ti.' },
            { icon: '📱', title: 'Desde cualquier lugar', desc: 'Funciona en celular, tablet y computadora. Sin instalación. Tus datos siempre disponibles.' },
          ].map(({ icon, title, desc }) => (
            <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm hover:shadow-md transition-shadow">
              <span class="text-3xl">{icon}</span>
              <h3 class="mt-3 font-display text-base font-bold text-slate-900">{title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-slate-600">{desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Excel highlight -->
    <section class="bg-white py-20">
      <div class="mx-auto max-w-5xl px-5">
        <div class="grid items-center gap-12 md:grid-cols-2">
          <div>
            <span class="inline-flex items-center gap-2 rounded-full border border-green-200 bg-green-50 px-3 py-1 text-xs font-semibold text-brand-green-dark">
              ✨ Favorita de los profes
            </span>
            <h2 class="mt-4 font-display text-3xl font-bold tracking-tight text-slate-900">
              Tu lista de estudiantes ya está en Excel. Úsala.
            </h2>
            <p class="mt-4 text-base leading-relaxed text-slate-600">
              No vuelvas a cargar estudiante por estudiante. Arrastra tu archivo, revisamos los datos y en segundos están todos listos.
            </p>
            <ul class="mt-6 space-y-3">
              {['Acepta .xlsx, .xls y .csv', 'Detecta las columnas automáticamente', 'Vista previa antes de confirmar', 'Descarga la plantilla si partes de cero'].map((item) => (
                <li class="flex items-center gap-2 text-sm text-slate-700">
                  <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-green-100 text-xs text-brand-green-dark font-bold">✓</span>
                  {item}
                </li>
              ))}
            </ul>
            <a href={registerUrl} class="mt-8 inline-flex rounded-xl bg-brand-blue px-6 py-3 text-sm font-bold text-white shadow-md transition hover:bg-brand-blue-dark">
              Probarlo gratis →
            </a>
          </div>
          <div class="rounded-2xl border border-slate-200 bg-slate-50 p-6 space-y-4">
            <div class="flex items-center gap-2 rounded-xl border-2 border-dashed border-slate-300 bg-white p-6 text-center flex-col cursor-pointer hover:border-brand-blue hover:bg-blue-50 transition-colors">
              <span class="text-4xl">📂</span>
              <p class="text-sm font-semibold text-slate-700">Arrastra tu Excel aquí</p>
              <p class="text-xs text-slate-400">o haz clic para seleccionar · .xlsx .xls .csv</p>
            </div>
            <div class="rounded-xl border border-green-200 bg-green-50 px-4 py-3 flex items-center gap-3">
              <span class="text-2xl">📗</span>
              <div>
                <p class="text-sm font-bold text-green-800">lista_6to_A.xlsx</p>
                <p class="text-xs text-green-600">✓ 28 estudiantes encontrados</p>
              </div>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white overflow-hidden text-sm">
              <div class="grid grid-cols-3 bg-slate-50 px-3 py-2 text-xs font-bold text-slate-500 uppercase tracking-wide">
                <span>Nombre</span><span>Apellido</span><span>Cédula</span>
              </div>
              {[['Ana', 'García', '1234...'], ['Juan', 'López', '0987...'], ['Sofía', 'Torres', '1122...']].map(([n, a, c]) => (
                <div class="grid grid-cols-3 border-t border-slate-100 px-3 py-2 text-xs text-slate-600">
                  <span>{n}</span><span>{a}</span><span class="text-slate-400">{c}</span>
                </div>
              ))}
              <div class="border-t border-slate-100 px-3 py-2 text-xs text-slate-400 text-center">… y 25 más</div>
            </div>
            <button class="w-full rounded-xl bg-brand-green py-2.5 text-sm font-bold text-white hover:bg-brand-green-dark transition">
              Confirmar importación ✓
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- Compartir con colegas -->
    <section class="bg-brand-gradient py-16">
      <div class="mx-auto max-w-3xl px-5 text-center">
        <p class="text-white/80 text-sm font-semibold uppercase tracking-wide mb-3">Ayuda a un colega</p>
        <h2 class="font-display text-3xl md:text-4xl font-extrabold text-white">
          ¿Cuántos profes de tu colegio siguen usando cuadernos y Excel?
        </h2>
        <p class="mt-4 text-white/80 text-base leading-relaxed max-w-xl mx-auto">
          Comparte Auleka con tus colegas. Es gratis para todos, para siempre. No les vas a cobrar nada — les estás regalando tiempo.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
          <a href={whatsappUrl} target="_blank" rel="noopener"
            class="inline-flex items-center justify-center gap-2 rounded-xl bg-[#25D366] px-6 py-3.5 text-base font-bold text-white shadow-lg transition hover:bg-[#20b558]">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 fill-white" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Compartir por WhatsApp
          </a>
          <button
            onclick="navigator.clipboard.writeText('https://auleka.com/personal').then(() => { this.textContent = '✓ Link copiado'; setTimeout(() => this.textContent = 'Copiar link', 2000) })"
            class="inline-flex items-center justify-center gap-2 rounded-xl border-2 border-white/40 px-6 py-3.5 text-base font-bold text-white transition hover:bg-white/10">
            Copiar link
          </button>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="bg-white py-20">
      <div class="mx-auto max-w-3xl px-5">
        <p class="text-center text-sm font-semibold uppercase tracking-wide text-brand-blue mb-3">Preguntas frecuentes</p>
        <h2 class="text-center font-display text-3xl font-bold tracking-tight text-slate-900 mb-10">Lo que siempre preguntan.</h2>
        <div class="space-y-4">
          {[
            {
              q: '¿De verdad es gratis para siempre?',
              a: 'Sí. Auleka para profesores individuales no tiene costo, sin límite de tiempo ni de estudiantes. El producto que se cobra es el institucional, que tiene funciones para rectores, DECE, matrículas e inspectoría.'
            },
            {
              q: '¿Necesito que mi institución use Auleka?',
              a: 'No. Tu aula personal es completamente independiente. La creas con tu email y trabajas solo o sola, sin necesidad de que nadie más en tu colegio use la plataforma.'
            },
            {
              q: '¿Qué pasa con mis datos si me voy?',
              a: 'Son tuyos. Puedes exportar tus calificaciones y reportes cuando quieras, y si decides dejar de usar Auleka tus datos pueden ser eliminados a solicitud.'
            },
            {
              q: '¿Funciona en el celular?',
              a: 'Sí, funciona en celular, tablet y computadora. Es una app web — no necesitas instalar nada desde ninguna tienda.'
            },
            {
              q: '¿Puedo dar clases particulares con esto?',
              a: 'Perfectamente. Puedes crear un aula con el nombre de tu academia o tus clases privadas, agregar tus alumnos y manejar sus calificaciones con tus propios criterios.'
            },
          ].map(({ q, a }) => (
            <details class="group rounded-xl border border-slate-200 bg-slate-50 p-5 cursor-pointer">
              <summary class="flex items-center justify-between font-semibold text-slate-800 text-sm list-none">
                {q}
                <span class="ml-4 shrink-0 text-brand-blue group-open:rotate-180 transition-transform">▼</span>
              </summary>
              <p class="mt-3 text-sm leading-relaxed text-slate-600">{a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA final -->
    <section class="bg-slate-50 py-20">
      <div class="mx-auto max-w-3xl px-5 text-center">
