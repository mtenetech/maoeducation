---
import Layout from '../layouts/Layout.astro'
import Footer from '../components/Footer.astro'

const appUrl = import.meta.env.PUBLIC_APP_URL || 'https://app.auleka.com'
const registerUrl = `${appUrl}/personal/register`
---

<Layout
  title="Auleka para Profesores — Tu aula digital en 5 minutos"
  description="Calificaciones, asistencia y reportes con tu logo. Sin depender de un sistema institucional. Crea tu aula gratis en Auleka."
>
  <!-- Header propio -->
  <header class="sticky top-0 z-40 border-b border-slate-100 bg-white/80 backdrop-blur">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-5 py-3">
      <a href="/" class="flex items-center gap-2" aria-label="Auleka — inicio">
        <img src="/isotipo.svg" alt="Auleka" width="34" height="34" />
        <span class="font-display text-xl font-bold tracking-tight text-slate-900">auleka</span>
      </a>
      <nav class="hidden items-center gap-7 text-sm font-medium text-slate-600 md:flex">
        <a href="#como-funciona" class="hover:text-brand-blue">Cómo funciona</a>
        <a href="#funciones" class="hover:text-brand-blue">Funciones</a>
        <a href="#precio" class="hover:text-brand-blue">Precio</a>
        <a href="/" class="hover:text-brand-blue">Para instituciones</a>
      </nav>
      <div class="flex items-center gap-3">
        <a href={`${appUrl}/personal/login`} class="hidden text-sm font-semibold text-slate-600 hover:text-brand-blue sm:inline">
          Ingresar
        </a>
        <a href={registerUrl} class="rounded-lg bg-brand-blue px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-brand-blue-dark">
          Crear aula gratis
        </a>
      </div>
    </div>
  </header>

  <main>
    <!-- Hero -->
    <section class="relative overflow-hidden">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-1 bg-brand-gradient"></div>
      <div class="pointer-events-none absolute -right-24 -top-24 h-96 w-96 rounded-full bg-brand-blue/5 blur-3xl"></div>
      <div class="pointer-events-none absolute -bottom-32 -left-24 h-96 w-96 rounded-full bg-brand-green/5 blur-3xl"></div>

      <div class="mx-auto grid max-w-6xl items-center gap-12 px-5 py-16 md:grid-cols-2 md:py-24">
        <div>
          <span class="inline-flex items-center gap-2 rounded-full border border-blue-200 bg-blue-50 px-3 py-1 text-xs font-semibold text-brand-blue">
            <span class="h-1.5 w-1.5 rounded-full bg-brand-blue"></span>
            Para profesores independientes · Gratis para empezar
          </span>

          <h1 class="mt-5 font-display text-4xl font-extrabold leading-[1.1] tracking-tight text-slate-900 md:text-5xl">
            Tu aula digital,
            <span class="bg-brand-gradient bg-clip-text text-transparent"> en 5 minutos.</span>
          </h1>

          <p class="mt-5 max-w-md text-lg leading-relaxed text-slate-600">
            Calificaciones, asistencia y reportes profesionales con tu logo —
            <span class="font-semibold text-slate-800">sin depender del sistema de tu institución.</span>
          </p>

          <div class="mt-6 flex flex-wrap gap-2">
            <span class="inline-flex items-center gap-1.5 rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold text-brand-blue">
              📚 Profe de materia
            </span>
            <span class="inline-flex items-center gap-1.5 rounded-full bg-green-50 px-3 py-1 text-xs font-semibold text-brand-green-dark">
              🏫 Profe de aula
            </span>
            <span class="inline-flex items-center gap-1.5 rounded-full bg-purple-50 px-3 py-1 text-xs font-semibold text-purple-700">
              🎓 Docente particular
            </span>
          </div>

          <div class="mt-8 flex flex-wrap items-center gap-3">
            <a href={registerUrl} class="rounded-lg bg-brand-blue px-6 py-3 text-base font-semibold text-white shadow-sm transition hover:bg-brand-blue-dark">
              Crear mi aula gratis →
            </a>
            <a href="#como-funciona" class="rounded-lg border border-slate-200 px-6 py-3 text-base font-semibold text-slate-700 transition hover:border-slate-300 hover:bg-slate-50">
              Ver cómo funciona
            </a>
          </div>

          <p class="mt-4 text-sm text-slate-500">Sin tarjeta de crédito · Sin instalación · Listo en minutos.</p>
        </div>

        <!-- Mockup wizard -->
        <div class="relative">
          <div class="rounded-2xl border border-slate-200 bg-white p-2 shadow-2xl shadow-slate-200/60">
            <div class="flex items-center gap-1.5 px-3 py-2">
              <span class="h-2.5 w-2.5 rounded-full bg-red-400"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-amber-400"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-green-400"></span>
              <span class="ml-2 text-xs text-slate-400">app.auleka.com/personal/setup</span>
            </div>
            <div class="rounded-xl bg-slate-50 p-5 space-y-4">
              <!-- Progress -->
              <div class="flex items-center gap-2">
                <div class="h-1.5 w-8 rounded-full bg-brand-blue"></div>
                <div class="h-1.5 w-8 rounded-full bg-brand-blue"></div>
                <div class="h-1.5 w-6 rounded-full bg-brand-blue opacity-40"></div>
                <div class="h-1.5 w-4 rounded-full bg-slate-200"></div>
                <div class="h-1.5 w-4 rounded-full bg-slate-200"></div>
                <span class="text-xs text-slate-400 ml-1">Paso 2 de 5</span>
              </div>
              <p class="text-xs font-semibold uppercase tracking-wide text-brand-blue">Mis clases</p>
              <p class="font-display text-base font-bold text-slate-900">¿Qué materia enseñas?</p>
              <div class="rounded-lg border border-brand-blue bg-white px-3 py-2 text-sm text-slate-700 ring-2 ring-brand-blue/20">
                Matemáticas
              </div>
              <p class="text-sm font-medium text-slate-700">¿A cuáles grupos?</p>
              <div class="space-y-2">
                <div class="rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm text-slate-600">3ro A</div>
                <div class="rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm text-slate-600">4to B</div>
                <button class="text-xs font-semibold text-brand-blue">+ Agregar grupo</button>
              </div>
              <button class="w-full rounded-lg bg-brand-blue py-2 text-sm font-semibold text-white">
                Siguiente →
              </button>
            </div>
          </div>
          <div class="absolute -bottom-4 -right-4 rounded-xl border border-slate-200 bg-white px-4 py-3 shadow-lg shadow-slate-200/60">
            <p class="text-xs font-semibold text-slate-800">📊 Importa desde Excel</p>
            <p class="text-xs text-slate-500">Sube tu lista y listo — sin cargar uno a uno</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="border-y border-slate-100 bg-white py-10">
      <div class="mx-auto max-w-5xl px-5">
        <div class="grid grid-cols-2 gap-6 text-center md:grid-cols-4">
          <div>
            <p class="font-display text-3xl font-extrabold bg-brand-gradient bg-clip-text text-transparent">5 min</p>
            <p class="mt-1 text-sm text-slate-600">Para configurar tu aula</p>
          </div>
          <div>
            <p class="font-display text-3xl font-extrabold bg-brand-gradient bg-clip-text text-transparent">Excel</p>
            <p class="mt-1 text-sm text-slate-600">Importa tu lista de alumnos</p>
          </div>
          <div>
            <p class="font-display text-3xl font-extrabold bg-brand-gradient bg-clip-text text-transparent">Gratis</p>
            <p class="mt-1 text-sm text-slate-600">Para empezar hoy mismo</p>
          </div>
          <div>
            <p class="font-display text-3xl font-extrabold bg-brand-gradient bg-clip-text text-transparent">Tu logo</p>
            <p class="mt-1 text-sm text-slate-600">En todos los reportes</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Cómo funciona -->
    <section id="como-funciona" class="bg-white py-20">
      <div class="mx-auto max-w-4xl px-5">
        <p class="text-center text-sm font-semibold uppercase tracking-wide text-brand-blue">Cómo funciona</p>
        <h2 class="mt-3 text-center font-display text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">
          De cero a calificando en 3 pasos.
        </h2>
        <div class="mt-12 grid gap-8 md:grid-cols-3">
          {[
            {
              step: '01',
              title: 'Crea tu cuenta',
              desc: 'Solo nombre, email y contraseña. Sin instituciones, sin códigos, sin papeleo. En 30 segundos.',
              color: 'blue',
            },
            {
              step: '02',
              title: 'Configura tus clases',
              desc: 'Dinos si enseñas una materia a varios grupos o varias materias al mismo grado. El wizard hace el resto.',
              color: 'green',
            },
            {
              step: '03',
              title: 'Empieza a trabajar',
              desc: 'Sube tu lista de estudiantes desde Excel, registra notas y asistencia, y genera reportes con tu logo.',
              color: 'blue',
            },
          ].map(({ step, title, desc, color }) => (
            <div class="relative flex flex-col gap-4">
              <div class={`inline-flex h-12 w-12 items-center justify-center rounded-xl font-display text-lg font-extrabold ${color === 'blue' ? 'bg-blue-50 text-brand-blue' : 'bg-green-50 text-brand-green-dark'}`}>
                {step}
              </div>
              <h3 class="font-display text-lg font-bold text-slate-900">{title}</h3>
              <p class="text-sm leading-relaxed text-slate-600">{desc}</p>
            </div>
          ))}
        </div>
        <div class="mt-12 text-center">
          <a href={registerUrl} class="inline-flex rounded-lg bg-brand-blue px-6 py-3 text-base font-semibold text-white shadow-sm transition hover:bg-brand-blue-dark">
            Empezar ahora — es gratis →
          </a>
        </div>
      </div>
    </section>

    <!-- Funciones -->
    <section id="funciones" class="bg-slate-50 py-20">
      <div class="mx-auto max-w-5xl px-5">
        <p class="text-center text-sm font-semibold uppercase tracking-wide text-brand-blue">Funciones</p>
        <h2 class="mt-3 text-center font-display text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">
          Todo lo que necesitas como profe.
        </h2>
        <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {[
            {
              icon: '📊',
              title: 'Importación desde Excel',
              desc: 'Sube tu lista de estudiantes en un archivo .xlsx. Detectamos las columnas automáticamente y te mostramos una vista previa antes de confirmar.',
            },
            {
              icon: '📝',
              title: 'Calificaciones completas',
              desc: 'Insumos, actividades y notas finales. El mismo motor que usan las instituciones, ahora disponible para ti.',
            },
            {
              icon: '📅',
              title: 'Asistencia por clase',
              desc: 'Registra asistencia por materia y paralelo. Visualiza porcentajes y ausencias de cada estudiante al instante.',
            },
            {
              icon: '📄',
              title: 'Reportes con tu logo',
              desc: 'Genera boletines y reportes en PDF con el nombre de tu academia o aula y tu logo. Aspecto profesional desde el primer día.',
            },
            {
              icon: '🎓',
              title: 'Para cualquier perfil',
              desc: 'Enseñas una materia a varios grupos o eres el profe de aula de un grado. El wizard se adapta a cómo trabajas tú.',
            },
            {
              icon: '⚙️',
              title: 'Sin complicaciones',
              desc: 'No necesitas que un administrador configure nada. Tú creas tu aula, tus materias y tus estudiantes.',
            },
          ].map(({ icon, title, desc }) => (
            <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
              <span class="text-2xl">{icon}</span>
              <h3 class="mt-3 font-display text-base font-bold text-slate-900">{title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-slate-600">{desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Excel highlight -->
    <section class="bg-white py-20">
      <div class="mx-auto max-w-5xl px-5">
        <div class="grid items-center gap-12 md:grid-cols-2">
          <div>
            <span class="inline-flex items-center gap-2 rounded-full border border-green-200 bg-green-50 px-3 py-1 text-xs font-semibold text-brand-green-dark">
              ✨ Funcionalidad estrella
            </span>
            <h2 class="mt-4 font-display text-3xl font-bold tracking-tight text-slate-900">
              Importa tu lista de estudiantes desde Excel.
            </h2>
            <p class="mt-4 text-base leading-relaxed text-slate-600">
              ¿Ya tienes tu lista en una hoja de cálculo? Arrastra el archivo, revisamos los datos y creamos todos los perfiles en segundos.
            </p>
            <ul class="mt-6 space-y-3">
              {[
                'Acepta .xlsx, .xls y .csv',
                'Detecta columnas automáticamente',
                'Vista previa antes de confirmar',
                'Descarga la plantilla si partes de cero',
              ].map((item) => (
                <li class="flex items-center gap-2 text-sm text-slate-700">
                  <span class="flex h-5 w-5 items-center justify-center rounded-full bg-green-100 text-xs text-brand-green-dark">✓</span>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <!-- Mockup Excel upload -->
          <div class="rounded-2xl border border-slate-200 bg-slate-50 p-6 space-y-4">
            <div class="flex items-center gap-2 rounded-xl border-2 border-dashed border-slate-300 bg-white p-6 text-center flex-col">
              <span class="text-3xl">📂</span>
              <p class="text-sm font-medium text-slate-700">Arrastra tu Excel aquí</p>
              <p class="text-xs text-slate-400">o haz clic para seleccionar</p>
            </div>
            <div class="rounded-xl border border-green-200 bg-green-50 px-4 py-3 flex items-center gap-2">
              <span class="text-green-600 text-lg">📗</span>
              <div>
                <p class="text-xs font-semibold text-green-800">lista_6to_A.xlsx</p>
                <p class="text-xs text-green-600">28 estudiantes encontrados</p>
              </div>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white overflow-hidden">
              <div class="grid grid-cols-3 bg-slate-50 px-3 py-1.5 text-xs font-semibold text-slate-500">
                <span>Nombre</span><span>Apellido</span><span>Cédula</span>
              </div>
              {[
                ['Ana', 'García', '1234...'],
                ['Juan', 'López', '0987...'],
                ['Sofía', 'Torres', '1122...'],
              ].map(([n, a, c]) => (
                <div class="grid grid-cols-3 border-t border-slate-100 px-3 py-1.5 text-xs text-slate-600">
                  <span>{n}</span><span>{a}</span><span class="text-slate-400">{c}</span>
                </div>
              ))}
              <div class="border-t border-slate-100 px-3 py-1.5 text-xs text-slate-400 text-center">… y 25 más</div>
            </div>
            <button class="w-full rounded-lg bg-brand-green py-2 text-sm font-semibold text-white">
              Confirmar importación ✓
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- Precio -->
    <section id="precio" class="bg-slate-50 py-20">
      <div class="mx-auto max-w-4xl px-5 text-center">
        <p class="text-sm font-semibold uppercase tracking-wide text-brand-blue">Precio</p>
        <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">
          Empieza gratis. Crece cuando quieras.
        </h2>
        <div class="mt-10 grid gap-6 md:grid-cols-2 max-w-2xl mx-auto">
          <!-- Gratis -->
          <div class="rounded-2xl border-2 border-slate-200 bg-white p-7 text-left shadow-sm">
            <p class="font-display text-lg font-bold text-slate-900">Gratis</p>
            <p class="mt-1 text-sm text-slate-500">Para empezar sin compromiso</p>
            <p class="mt-4 font-display text-4xl font-extrabold text-slate-900">$0</p>
            <ul class="mt-6 space-y-2.5">
              {[
                'Hasta 30 estudiantes',
                'Calificaciones y asistencia',
                'Importación desde Excel',
                'Reportes en PDF',
                'Wizard de configuración',
              ].map((item) => (
                <li class="flex items-start gap-2 text-sm text-slate-700">
                  <span class="mt-0.5 text-brand-green">✓</span> {item}
                </li>
              ))}
            </ul>
            <a href={registerUrl} class="mt-6 inline-flex w-full justify-center rounded-lg border border-brand-blue px-6 py-2.5 text-sm font-semibold text-brand-blue transition hover:bg-blue-50">
              Crear cuenta gratis
            </a>
          </div>

          <!-- Pro -->
          <div class="rounded-2xl border-2 border-brand-blue bg-white p-7 text-left shadow-sm relative overflow-hidden">
            <div class="absolute inset-x-0 top-0 h-1 bg-brand-gradient"></div>
            <div class="flex items-center justify-between">
              <p class="font-display text-lg font-bold text-slate-900">Pro</p>
              <span class="rounded-full bg-blue-50 px-2 py-0.5 text-xs font-semibold text-brand-blue">Popular</span>
            </div>
            <p class="mt-1 text-sm text-slate-500">Para profesores con más alumnos</p>
            <p class="mt-4 font-display text-4xl font-extrabold text-slate-900">$1 <span class="text-lg font-normal text-slate-500">/ estudiante / año</span></p>
            <ul class="mt-6 space-y-2.5">
              {[
                'Estudiantes ilimitados',
                'Todo lo del plan Gratis',
                'Logo personalizado en reportes',
                'Múltiples materias y grupos',
                'Soporte prioritario',
              ].map((item) => (
                <li class="flex items-start gap-2 text-sm text-slate-700">
                  <span class="mt-0.5 text-brand-green">✓</span> {item}
                </li>
              ))}
            </ul>
            <a href={registerUrl} class="mt-6 inline-flex w-full justify-center rounded-lg bg-brand-blue px-6 py-2.5 text-sm font-semibold text-white transition hover:bg-brand-blue-dark">
              Comenzar — 30 días gratis
            </a>
            <p class="mt-2 text-xs text-center text-slate-400">Sin tarjeta de crédito requerida</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA final -->
    <section class="bg-white py-20">
      <div class="mx-auto max-w-3xl px-5 text-center">
        <h2 class="font-display text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">
          Tu aula digital te espera.
        </h2>
        <p class="mt-4 text-lg text-slate-600">
          Únete a los docentes que ya gestionan sus clases con Auleka — sin depender de nadie más.
        </p>
        <a href={registerUrl} class="mt-8 inline-flex rounded-lg bg-brand-blue px-8 py-3.5 text-base font-semibold text-white shadow-sm transition hover:bg-brand-blue-dark">
          Crear mi aula gratis →
        </a>
        <p class="mt-3 text-sm text-slate-400">Sin tarjeta · Sin instalación · En 5 minutos</p>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
