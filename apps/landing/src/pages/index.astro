---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import Hero from '../components/Hero.astro'
import Features from '../components/Features.astro'
import WhyAuleka from '../components/WhyAuleka.astro'
import DemoForm from '../components/DemoForm.astro'
import Footer from '../components/Footer.astro'
---

<Layout>
  <Header />
  <main>
    <Hero />

    <!-- Stats -->
    <section class="border-y border-slate-100 bg-white py-10">
      <div class="mx-auto max-w-5xl px-5">
        <div class="grid grid-cols-2 gap-6 text-center md:grid-cols-4">
          <div>
            <p class="font-display text-3xl font-extrabold bg-brand-gradient bg-clip-text text-transparent">100%</p>
            <p class="mt-1 text-sm text-slate-600">Conforme a MINEDUC</p>
          </div>
          <div>
            <p class="font-display text-3xl font-extrabold bg-brand-gradient bg-clip-text text-transparent">-70%</p>
            <p class="mt-1 text-sm text-slate-600">Tiempo en papeleo</p>
          </div>
          <div>
            <p class="font-display text-3xl font-extrabold bg-brand-gradient bg-clip-text text-transparent">$5</p>
            <p class="mt-1 text-sm text-slate-600">Por familia · al año</p>
          </div>
          <div>
            <p class="font-display text-3xl font-extrabold bg-brand-gradient bg-clip-text text-transparent">24/7</p>
            <p class="mt-1 text-sm text-slate-600">Desde cualquier dispositivo</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Problema → Solución -->
    <section class="bg-slate-50 py-16">
      <div class="mx-auto max-w-4xl px-5">
        <p class="text-center text-sm font-semibold uppercase tracking-wide text-brand-blue mb-8">¿Te suena familiar?</p>
        <div class="grid gap-6 md:grid-cols-2">
          <div class="rounded-2xl border border-red-100 bg-red-50 p-6">
            <p class="text-xs font-bold uppercase tracking-wider text-red-400 mb-4">❌ Sin Auleka</p>
            <ul class="space-y-3 text-sm text-slate-700">
              <li class="flex items-start gap-2"><span class="text-red-400 shrink-0">✗</span> Docentes hasta medianoche en Excel en el cierre</li>
              <li class="flex items-start gap-2"><span class="text-red-400 shrink-0">✗</span> Los padres se enteran de las notas cuando ya es tarde</li>
              <li class="flex items-start gap-2"><span class="text-red-400 shrink-0">✗</span> Papeles perdidos, datos duplicados, expedientes incompletos</li>
              <li class="flex items-start gap-2"><span class="text-red-400 shrink-0">✗</span> El DECE sin trazabilidad de los casos</li>
              <li class="flex items-start gap-2"><span class="text-red-400 shrink-0">✗</span> El rector sin visibilidad real de la institución</li>
            </ul>
          </div>
          <div class="rounded-2xl border border-green-100 bg-green-50 p-6">
            <p class="text-xs font-bold uppercase tracking-wider text-brand-green-dark mb-4">✅ Con Auleka</p>
            <ul class="space-y-3 text-sm text-slate-700">
              <li class="flex items-start gap-2"><span class="text-brand-green shrink-0">✓</span> Boletines generados automáticamente en un clic</li>
              <li class="flex items-start gap-2"><span class="text-brand-green shrink-0">✓</span> Padres notificados al instante en su celular</li>
              <li class="flex items-start gap-2"><span class="text-brand-green shrink-0">✓</span> Todo el historial del estudiante en un solo lugar</li>
              <li class="flex items-start gap-2"><span class="text-brand-green shrink-0">✓</span> Casos DECE documentados con debido proceso</li>
              <li class="flex items-start gap-2"><span class="text-brand-green shrink-0">✓</span> Control total en tiempo real</li>
            </ul>
          </div>
        </div>
        <div class="mt-8 text-center">
          <a href="#demo" class="inline-flex rounded-lg bg-brand-blue px-6 py-3 text-base font-semibold text-white shadow-sm transition hover:bg-brand-blue-dark">
            Quiero verlo en acción →
          </a>
        </div>
      </div>
    </section>

    <Features />
    <WhyAuleka />

    <!-- Precio -->
    <section id="precio" class="bg-slate-50 py-20">
      <div class="mx-auto max-w-3xl px-5 text-center">
        <p class="text-sm font-semibold uppercase tracking-wide text-brand-blue">Precio accesible para toda institución</p>
        <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">
          Menos de lo que cuesta un café al mes por familia.
        </h2>
        <p class="mt-4 text-lg text-slate-600">
          Auleka cuesta <strong class="text-slate-800">$5 por familia al año</strong> — lo que el comité de padres
          ya recauda normalmente. Una sola inversión que transforma toda la gestión.
        </p>
        <div class="mx-auto mt-10 max-w-md rounded-2xl border-2 border-brand-blue/20 bg-white p-8 shadow-sm relative overflow-hidden">
          <div class="absolute inset-x-0 top-0 h-1 bg-brand-gradient"></div>
          <p class="font-display text-4xl font-extrabold text-slate-900">$5 <span class="text-lg font-normal text-slate-500">/ familia / año</span></p>
          <p class="mt-2 text-sm text-slate-500">500 familias = $2.500/año · 750 familias = $3.750/año</p>
          <p class="mt-1 text-xs font-semibold text-brand-green-dark">Equivale a $0.42 por familia al mes</p>
          <ul class="mt-6 space-y-2.5 text-left text-slate-700">
            {['Portal para padres incluido','Migración de tus datos actuales','Capacitación a docentes y administrativos','Actualizaciones permanentes','Soporte local en Ecuador','Todas las funciones sin módulos extra'].map((item) => (
              <li class="flex items-start gap-2 text-sm"><span class="mt-0.5 text-brand-green">✓</span> {item}</li>
            ))}
          </ul>
          <a href="#demo" class="mt-6 inline-flex w-full justify-center rounded-lg bg-brand-blue px-6 py-3 text-base font-semibold text-white transition hover:bg-brand-blue-dark">
            Solicitar propuesta personalizada
          </a>
          <p class="mt-3 text-xs text-slate-400">Armamos el costo exacto para tu institución en la demo — sin compromiso.</p>
        </div>
      </div>
    </section>

    <DemoForm />
  </main>
  <Footer />
</Layout>
