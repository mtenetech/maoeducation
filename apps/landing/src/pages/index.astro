---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import Hero from '../components/Hero.astro'
import Features from '../components/Features.astro'
import WhyAuleka from '../components/WhyAuleka.astro'
import DemoForm from '../components/DemoForm.astro'
import Footer from '../components/Footer.astro'
---

<Layout>
  <Header />
  <main>
    <Hero />

    <!-- Problema -> Solución -->
    <section class="border-y border-slate-100 bg-white py-16">
      <div class="mx-auto max-w-4xl px-5 text-center">
        <p class="text-sm font-semibold uppercase tracking-wide text-brand-blue">El cierre de quimestre no debería ser un caos</p>
        <h2 class="mt-3 font-display text-2xl font-bold text-slate-900 md:text-3xl">
          Tus profes pasan horas en Excel. Tu información vive en mil archivos. Las familias preguntan y nadie tiene la respuesta a la mano.
        </h2>
        <p class="mt-5 text-lg text-slate-600">
          Auleka reúne notas, asistencia, matrícula, DECE y la carpeta de cada estudiante en una sola plataforma —
          ordenada, segura y conforme a MINEDUC.
        </p>
      </div>
    </section>

    <Features />
    <WhyAuleka />

    <!-- Planes -->
    <section id="precio" class="bg-slate-50 py-20">
      <div class="mx-auto max-w-3xl px-5 text-center">
        <h2 class="font-display text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">
          Planes a la medida de tu colegio
        </h2>
        <p class="mt-4 text-lg text-slate-600">
          El precio se ajusta al número de estudiantes, con descuento por contrato anual y por grupos de colegios.
          Te armamos una propuesta clara en la demo.
        </p>
        <div class="mx-auto mt-10 max-w-md rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
          <p class="font-display text-sm font-semibold uppercase tracking-wide text-brand-green-dark">Incluye siempre</p>
          <ul class="mt-4 space-y-2.5 text-left text-slate-700">
            <li class="flex items-start gap-2"><span class="mt-0.5 text-brand-green">✓</span> Migración de tus datos</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-brand-green">✓</span> Capacitación a tu equipo</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-brand-green">✓</span> Actualizaciones y soporte local</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-brand-green">✓</span> Todas las funciones, sin módulos extra</li>
          </ul>
          <a href="#demo" class="mt-6 inline-flex w-full justify-center rounded-lg bg-brand-blue px-6 py-3 text-base font-semibold text-white transition hover:bg-brand-blue-dark">
            Pide tu propuesta
          </a>
        </div>
      </div>
    </section>

    <DemoForm />
  </main>
  <Footer />
</Layout>
