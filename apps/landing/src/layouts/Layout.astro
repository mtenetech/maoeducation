---
interface Props {
  title?: string
  description?: string
}

const {
  title = 'Auleka — La plataforma de gestión para tu institución educativa',
  description = 'Auleka es la plataforma integral de gestión para instituciones educativas de Ecuador: notas MINEDUC, asistencia, matrícula, DECE y portal para padres. Menos papeleo, más enseñar.',
} = Astro.props

const canonical = new URL(Astro.url.pathname, Astro.site).toString()
const ogImage = new URL('/og-image.svg', Astro.site).toString()
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph / redes -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="es_EC" />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Fuentes -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-white font-sans text-slate-800 antialiased">
    <slot />

    <!-- Botón flotante WhatsApp -->
    <a
      href="https://wa.me/593981968559?text=Hola%2C%20quiero%20saber%20m%C3%A1s%20sobre%20Auleka%20para%20mi%20instituci%C3%B3n"
      target="_blank"
      rel="noopener"
      aria-label="Escríbenos por WhatsApp"
      class="fixed bottom-6 right-6 z-50 flex h-14 w-14 items-center justify-center rounded-full bg-[#25D366] shadow-lg shadow-green-500/30 transition hover:scale-110 hover:shadow-xl hover:shadow-green-500/40"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 fill-white" viewBox="0 0 24 24">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
    </a>

    <script>
      const apiUrl = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000'

      // Id anónimo por navegador para poder distinguir visitantes en las estadísticas,
      // sin recolectar ningún dato personal.
      let visitorId = localStorage.getItem('auleka_vid')
      if (!visitorId) {
        visitorId = crypto.randomUUID()
        localStorage.setItem('auleka_vid', visitorId)
      }

      fetch(`${apiUrl}/api/v1/analytics/pageview`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          path: location.pathname,
          referrer: document.referrer || undefined,
          visitorId,
        }),
        keepalive: true,
      }).catch(() => {
        /* el tracking nunca debe romper la navegación */
      })
    </script>
  </body>
</html>

<style is:global>
  html {
    -webkit-font-smoothing: antialiased;
  }
</style>
