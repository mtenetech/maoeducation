---
---

<section class="relative overflow-hidden">
  <div class="pointer-events-none absolute inset-x-0 top-0 h-1 bg-brand-gradient"></div>
  <div class="pointer-events-none absolute -right-24 -top-24 h-96 w-96 rounded-full bg-brand-blue/5 blur-3xl"></div>
  <div class="pointer-events-none absolute -bottom-32 -left-24 h-96 w-96 rounded-full bg-brand-green/5 blur-3xl"></div>

  <div class="mx-auto grid max-w-6xl items-center gap-12 px-5 py-16 md:grid-cols-2 md:py-24">
    <div>
      <span class="inline-flex items-center gap-2 rounded-full border border-green-200 bg-green-50 px-3 py-1 text-xs font-semibold text-brand-green-dark">
        <span class="h-1.5 w-1.5 rounded-full bg-brand-green"></span>
        Hecho para Ecuador · 100% conforme a MINEDUC
      </span>

      <h1 class="mt-5 font-display text-4xl font-extrabold leading-[1.1] tracking-tight text-slate-900 md:text-5xl">
        La plataforma que tu institución
        <span class="bg-brand-gradient bg-clip-text text-transparent"> necesitaba desde siempre.</span>
      </h1>

      <p class="mt-5 max-w-md text-lg leading-relaxed text-slate-600">
        Notas, asistencia, matrícula, DECE y comunicación con padres — todo en un solo lugar.
        <span class="font-semibold text-slate-800">Los docentes menos tiempo en papeleo. Los padres siempre informados.</span>
      </p>

      <!-- Audiencias -->
      <div class="mt-6 flex flex-wrap gap-2">
        <span class="inline-flex items-center gap-1.5 rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold text-brand-blue">
          🏫 Para rectores y docentes
        </span>
        <span class="inline-flex items-center gap-1.5 rounded-full bg-green-50 px-3 py-1 text-xs font-semibold text-brand-green-dark">
          👨‍👩‍👧 Para padres de familia
        </span>
      </div>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a href="#demo" class="rounded-lg bg-brand-blue px-6 py-3 text-base font-semibold text-white shadow-sm transition hover:bg-brand-blue-dark">
          Solicita una demo gratis
        </a>
        <a href="#padres" class="rounded-lg border border-slate-200 px-6 py-3 text-base font-semibold text-slate-700 transition hover:border-slate-300 hover:bg-slate-50">
          Soy padre de familia →
        </a>
      </div>

      <p class="mt-4 text-sm text-slate-500">Sin compromiso · sin contrato · la demo es con tus datos reales.</p>
    </div>

    <!-- mockup -->
    <div class="relative">
      <div class="rounded-2xl border border-slate-200 bg-white p-2 shadow-2xl shadow-slate-200/60">
        <div class="flex items-center gap-1.5 px-3 py-2">
          <span class="h-2.5 w-2.5 rounded-full bg-red-400"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-amber-400"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-green-400"></span>
        </div>
        <div class="rounded-xl bg-slate-50 p-5">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <img src="/isotipo.svg" alt="" width="28" height="28" />
              <span class="font-display text-sm font-bold text-slate-800">Boletín listo — Trimestre 2</span>
            </div>
            <span class="rounded-full bg-green-100 px-2 py-0.5 text-xs font-semibold text-brand-green-dark">✓ Al día</span>
          </div>
          <div class="mt-4 space-y-2.5">
            <div class="flex items-center justify-between rounded-lg bg-white px-3 py-2.5 shadow-sm">
              <span class="text-sm text-slate-600">Matemáticas · 8.º A</span>
              <span class="text-sm font-semibold text-slate-800">9.2 — AAR</span>
            </div>
            <div class="flex items-center justify-between rounded-lg bg-white px-3 py-2.5 shadow-sm">
              <span class="text-sm text-slate-600">Lengua · 8.º A</span>
              <span class="text-sm font-semibold text-slate-800">8.7 — AAR</span>
            </div>
            <div class="flex items-center justify-between rounded-lg bg-white px-3 py-2.5 shadow-sm">
              <span class="text-sm text-slate-600">Comportamiento</span>
              <span class="text-sm font-semibold text-brand-green-dark">A — Muy satisfactorio</span>
            </div>
          </div>
          <!-- notificación push -->
          <div class="mt-4 rounded-lg border border-blue-100 bg-blue-50 px-3 py-2 flex items-start gap-2">
            <span class="text-base">🔔</span>
            <p class="text-xs text-blue-700"><strong>Mamá de Sofía:</strong> "El boletín del trimestre ya está disponible"</p>
          </div>
        </div>
      </div>
      <!-- badge flotante -->
      <div class="absolute -bottom-4 -right-4 rounded-xl border border-slate-200 bg-white px-4 py-3 shadow-lg shadow-slate-200/60">
        <p class="text-xs font-semibold text-slate-800">📱 Los padres reciben notificaciones al instante</p>
        <p class="text-xs text-slate-500">asistencia · notas · incidentes · mensajes</p>
      </div>
    </div>
  </div>
</section>
