---
const features = [
  {
    title: 'Calificaciones MINEDUC',
    desc: 'Insumos, exámenes, promedios, comportamiento, supletorios y promoción — calculado conforme a la normativa.',
    icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    title: 'Asistencia',
    desc: 'Registro por materia o diario, con justificaciones. Reportes de inasistencia en un clic.',
    icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
  },
  {
    title: 'Matrícula',
    desc: 'Matricula a cada estudiante en minutos, con anamnesis y datos del representante incluidos.',
    icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z',
  },
  {
    title: 'DECE e incidentes',
    desc: 'Registra incidentes con debido proceso: bitácora, notificación al representante y actas de compromiso.',
    icon: 'M3 6l9-4 9 4v6c0 5-3.8 8.4-9 10-5.2-1.6-9-5-9-10V6z',
  },
  {
    title: 'Carpeta del estudiante',
    desc: 'Toda la historia de cada niño en un solo lugar: notas, asistencia, incidentes y documentos.',
    icon: 'M3 7a2 2 0 012-2h4l2 2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V7z',
  },
  {
    title: 'Reportes',
    desc: 'Libretas, certificados y reportes listos para imprimir o enviar a las familias.',
    icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
  },
]
---

<section id="features" class="bg-slate-50 py-20">
  <div class="mx-auto max-w-6xl px-5">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="font-display text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">
        Todo lo que tu colegio necesita
      </h2>
      <p class="mt-4 text-lg text-slate-600">
        Una sola plataforma para lo académico, lo administrativo y el bienestar estudiantil.
      </p>
    </div>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((f) => (
        <div class="group rounded-2xl border border-slate-200 bg-white p-6 transition hover:-translate-y-0.5 hover:border-brand-blue/30 hover:shadow-lg hover:shadow-slate-200/60">
          <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-brand-gradient text-white">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d={f.icon} />
            </svg>
          </div>
          <h3 class="mt-4 font-display text-lg font-semibold text-slate-900">{f.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-600">{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
