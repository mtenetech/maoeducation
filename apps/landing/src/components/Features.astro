---
const features = [
  {
    title: 'Calificaciones MINEDUC',
    desc: 'Insumos, exámenes, promedios, comportamiento, recuperaciones y supletorios. Calculado automáticamente según la normativa. El boletín listo en un clic.',
    icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
    badge: 'Ahorra 4 horas por docente en cada cierre',
  },
  {
    title: 'Asistencia inteligente',
    desc: 'Registro por materia o diario. Los padres reciben una notificación al instante cuando su hijo/a falta o llega tarde. Sin llamadas. Sin incertidumbre.',
    icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
    badge: 'Notificación automática a los padres',
  },
  {
    title: 'Matrículas y anamnesis',
    desc: 'Matricula a cada estudiante en minutos con ficha de anamnesis completa. Sin papeles perdidos ni expedientes duplicados.',
    icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z',
    badge: 'Toda la historia del estudiante en un lugar',
  },
  {
    title: 'DECE e incidentes',
    desc: 'Registra incidentes con debido proceso: bitácora, notificación al representante, actas de compromiso y seguimiento. Todo documentado y seguro.',
    icon: 'M3 6l9-4 9 4v6c0 5-3.8 8.4-9 10-5.2-1.6-9-5-9-10V6z',
    badge: 'Proceso completo y trazable',
  },
  {
    title: 'Portal para padres',
    desc: 'Los padres ven notas, asistencia, tareas e incidentes desde su celular. Sin pedir permiso al docente. Sin esperar el boletín físico.',
    icon: 'M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z',
    badge: 'Incluido — sin costo extra',
  },
  {
    title: 'Reportes y boletines',
    desc: 'Libretas, certificados, actas de compromiso y reportes de asistencia listos para descargar o compartir. El rector tiene visibilidad total.',
    icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
    badge: 'Documentos con el logo de tu institución',
  },
]
---

<section id="features" class="bg-slate-50 py-20">
  <div class="mx-auto max-w-6xl px-5">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="font-display text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">
        Todo lo que tu institución necesita
      </h2>
      <p class="mt-4 text-lg text-slate-600">
        Una sola plataforma para lo académico, lo administrativo, el bienestar estudiantil y la comunicación con las familias.
      </p>
    </div>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((f) => (
        <div class="group flex flex-col rounded-2xl border border-slate-200 bg-white p-6 transition hover:-translate-y-0.5 hover:border-brand-blue/30 hover:shadow-lg hover:shadow-slate-200/60">
          <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-brand-gradient text-white">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d={f.icon} />
            </svg>
          </div>
          <h3 class="mt-4 font-display text-lg font-semibold text-slate-900">{f.title}</h3>
          <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-600">{f.desc}</p>
          <div class="mt-4 inline-flex items-center gap-1.5 rounded-full bg-green-50 px-3 py-1 text-xs font-semibold text-brand-green-dark">
            <span class="text-brand-green">✓</span> {f.badge}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
