---
const reasons = [
  {
    title: 'Hecho para Ecuador',
    desc: 'Quimestres, comportamiento, supletorios y promoción según la normativa MINEDUC. No tienes que adaptar nada.',
  },
  {
    title: 'Fácil para el profe',
    desc: 'Sube las notas una vez y listo. Sin Excel, sin fórmulas, sin pasar las noches en vela en el cierre.',
  },
  {
    title: 'Todo en uno',
    desc: 'Académico, matrícula, DECE y bienestar en la misma plataforma. Una sola fuente de verdad por estudiante.',
  },
  {
    title: 'Te acompañamos',
    desc: 'Migramos tus datos y capacitamos a tu equipo. Soporte local, en tu idioma y tu horario.',
  },
]
---

<section id="por-que" class="py-20">
  <div class="mx-auto max-w-6xl px-5">
    <div class="grid items-center gap-12 md:grid-cols-2">
      <div>
        <h2 class="font-display text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">
          ¿Por qué los colegios eligen Auleka?
        </h2>
        <p class="mt-4 text-lg text-slate-600">
          Porque deja de pelearse con planillas y empieza a recuperar tiempo — sin cambiar cómo trabaja tu institución.
        </p>
        <a
          href="#demo"
          class="mt-6 inline-flex rounded-lg bg-brand-blue px-6 py-3 text-base font-semibold text-white shadow-sm transition hover:bg-brand-blue-dark"
        >
          Agenda tu demo
        </a>
      </div>

      <div class="grid gap-5 sm:grid-cols-2">
        {reasons.map((r) => (
          <div class="rounded-xl border border-slate-200 bg-white p-5">
            <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-green-100 text-brand-green-dark">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <h3 class="mt-3 font-display text-base font-semibold text-slate-900">{r.title}</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-slate-600">{r.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
